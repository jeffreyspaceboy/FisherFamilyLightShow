    <Element type="timing" name="Main Vocal">
      <EffectLayer>
        <Effect label="What's this? What's this?" startTime="27150" endTime="28550"></Effect>
        <Effect label="There's color everywhere" startTime="28550" endTime="29950"></Effect>
        <Effect label="What's this?" startTime="29950" endTime="30550"></Effect>
        <Effect label="There's white things in the air" startTime="30550" endTime="32100"></Effect>
        <Effect label="What's this?" startTime="32100" endTime="32750"></Effect>
        <Effect label="I can't believe my eyes" startTime="32850" endTime="34000"></Effect>
        <Effect label="I must be dreaming" startTime="34000" endTime="34800"></Effect>
        <Effect label="Wake up, Jack, this isn't fair" startTime="34800" endTime="36350"></Effect>
        <Effect label="What's this?" startTime="36350" endTime="37300"></Effect>
        <Effect label="What's this? What's this?" startTime="39150" endTime="40600"></Effect>
        <Effect label="There's something very wrong" startTime="40600" endTime="42050"></Effect>
        <Effect label="What's this?" startTime="42050" endTime="42800"></Effect>
        <Effect label="There's people singing songs" startTime="42800" endTime="44050"></Effect>
        <Effect label="What's this?" startTime="44050" endTime="44950"></Effect>
        <Effect label="The streets are lined with" startTime="44950" endTime="45800"></Effect>
        <Effect label="Little creatures laughing" startTime="45800" endTime="46900"></Effect>
        <Effect label="Everybody seems so happy" startTime="46900" endTime="48250"></Effect>
        <Effect label="Have I possibly gone daffy?" startTime="48250" endTime="49750"></Effect>
        <Effect label="What is this?" startTime="49750" endTime="50750"></Effect>
        <Effect label="What's this?" startTime="51150" endTime="52100"></Effect>
        <Effect label="There are children throwing snowballs here" startTime="54000" endTime="55650"></Effect>
        <Effect label="Instead of throwing heads" startTime="55650" endTime="56800"></Effect>
        <Effect label="They're busy building toys" startTime="56800" endTime="58300"></Effect>
        <Effect label="And absolutely no one's dead" startTime="58300" endTime="59650"></Effect>
        <Effect label="There's frost on every window" startTime="59650" endTime="61100"></Effect>
        <Effect label="Oh, I can't believe my eyes" startTime="61100" endTime="62750"></Effect>
        <Effect label="And in my bones I feel the warmth" startTime="62750" endTime="64750"></Effect>
        <Effect label="That's coming from inside" startTime="64750" endTime="68600"></Effect>
        <Effect label="Oh, look" startTime="68600" endTime="69200"></Effect>
        <Effect label="What's this?" startTime="69200" endTime="70050"></Effect>
        <Effect label="They're hanging mistletoe, they kiss" startTime="70050" endTime="72100"></Effect>
        <Effect label="Why that looks so unique, inspired" startTime="72100" endTime="74250"></Effect>
        <Effect label="They're gathering around to hear a story" startTime="74250" endTime="76250"></Effect>
        <Effect label="Roasting chestnuts on a fire" startTime="76250" endTime="77800"></Effect>
        <Effect label="What's this?" startTime="77800" endTime="78600"></Effect>
        <Effect label="What's this?" startTime="80750" endTime="81350"></Effect>
        <Effect label="In here they've got a little tree, how queer" startTime="81500" endTime="84250"></Effect>
        <Effect label="And who would ever think" startTime="84350" endTime="85600"></Effect>
        <Effect label="And why?" startTime="85600" endTime="86300"></Effect>
        <Effect label="They're covering it with tiny little things" startTime="86300" endTime="88200"></Effect>
        <Effect label="They've got electric lights on strings" startTime="88200" endTime="89800"></Effect>
        <Effect label="And there's a smile on everyone" startTime="89800" endTime="91100"></Effect>
        <Effect label="So, now, correct me if I'm wrong" startTime="91100" endTime="92550"></Effect>
        <Effect label="This looks like fun" startTime="92550" endTime="93250"></Effect>
        <Effect label="This looks like fun" startTime="93250" endTime="93950"></Effect>
        <Effect label="Oh, could it be I got my wish?" startTime="93950" endTime="95700"></Effect>
        <Effect label="What's this?" startTime="95700" endTime="96500"></Effect>
        <Effect label="Oh my, what now?" startTime="98550" endTime="99850"></Effect>
        <Effect label="The children are asleep" startTime="99850" endTime="101200"></Effect>
        <Effect label="But look, there's nothing underneath" startTime="101200" endTime="103350"></Effect>
        <Effect label="No ghouls, no witches here to scream and scare them" startTime="103350" endTime="105850"></Effect>
        <Effect label="Or ensnare them, only little cozy things" startTime="105850" endTime="108050"></Effect>
        <Effect label="Secure inside their dreamland" startTime="108050" endTime="112400"></Effect>
        <Effect label="What's this?" startTime="114350" endTime="115150"></Effect>
        <Effect label="The monsters are all missing" startTime="117300" endTime="118700"></Effect>
        <Effect label="And the nightmares can't be found" startTime="118700" endTime="120100"></Effect>
        <Effect label="And in their place there seems to be" startTime="120100" endTime="121500"></Effect>
        <Effect label="Good feeling all around" startTime="121500" endTime="122950"></Effect>
        <Effect label="Instead of screams, I swear" startTime="122950" endTime="124300"></Effect>
        <Effect label="I can hear music in the air" startTime="124300" endTime="125800"></Effect>
        <Effect label="The smell of cakes and pies" startTime="125800" endTime="127150"></Effect>
        <Effect label="Is absolutely everywhere" startTime="127150" endTime="131100"></Effect>
        <Effect label="The sights, the sounds" startTime="131100" endTime="132550"></Effect>
        <Effect label="They're everywhere and all around" startTime="132550" endTime="134750"></Effect>
        <Effect label="I've never felt so good before" startTime="134750" endTime="136950"></Effect>
        <Effect label="This empty place inside of me is filling up" startTime="136950" endTime="139050"></Effect>
        <Effect label="I simply cannot get enough" startTime="139050" endTime="140400"></Effect>
        <Effect label="I want it, oh, I want it" startTime="140400" endTime="141800"></Effect>
        <Effect label="Oh, I want it for my own" startTime="141800" endTime="143000"></Effect>
        <Effect label="I've got to know" startTime="143000" endTime="143900"></Effect>
        <Effect label="I've got to know" startTime="143900" endTime="144550"></Effect>
        <Effect label="What is this place that I have found?" startTime="144550" endTime="146350"></Effect>
        <Effect label="What is this?" startTime="146350" endTime="149150"></Effect>
      </EffectLayer>
